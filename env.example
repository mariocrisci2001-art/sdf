import React, { useState, useEffect } from 'react';
import { Share, PlusSquare, X } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';

export default function InstallPrompt() {
  const [show, setShow] = useState(false);
  const [platform, setPlatform] = useState<'ios' | 'android' | 'other'>('other');

  useEffect(() => {
    // Check if already installed
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone;
    
    if (isStandalone) return;

    // Detect platform
    const ua = window.navigator.userAgent.toLowerCase();
    if (/iphone|ipad|ipod/.test(ua)) {
      setPlatform('ios');
      // Show after a delay on iOS
      const timer = setTimeout(() => setShow(true), 3000);
      return () => clearTimeout(timer);
    } else if (/android/.test(ua)) {
      setPlatform('android');
      // Android usually handles this via beforeinstallprompt, but we can show instructions too
    }
  }, []);

  if (!show) return null;

  return (
    <AnimatePresence>
      <motion.div
        initial={{ y: 100, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        exit={{ y: 100, opacity: 0 }}
        className="fixed bottom-6 left-6 right-6 bg-zinc-900 border border-white/10 rounded-2xl p-4 shadow-2xl z-[100] flex items-center justify-between"
      >
        <div className="flex items-center gap-3">
          <div className="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center border border-white/10">
            <img src="/icon.svg" className="w-8 h-8" alt="App Icon" />
          </div>
          <div className="flex flex-col">
            <span className="text-white text-sm font-bold">Installa MCS</span>
            <div className="flex items-center gap-1 text-[10px] text-white/50 font-medium uppercase tracking-wider">
              {platform === 'ios' ? (
                <>Tocca <Share className="w-3 h-3 inline" /> poi "Aggiungi a Home"</>
              ) : (
                <>Installa per un'esperienza completa</>
              )}
            </div>
          </div>
        </div>
        
        <div className="flex items-center gap-2">
            <button 
                onClick={() => setShow(false)}
                className="p-2 text-white/40 hover:text-white"
            >
                <X className="w-4 h-4" />
            </button>
        </div>
      </motion.div>
    </AnimatePresence>
  );
}
